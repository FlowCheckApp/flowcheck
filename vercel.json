{
  "version": 2,
  "functions": {
    "api/*.js": {
      "includeFiles": "node_modules/firebase-admin/**"
    }
  },
  "routes": [
    { "src": "/api/create-link-token", "dest": "/api/create-link-token.js" },
    { "src": "/api/exchange-token",    "dest": "/api/exchange_token.js" },
    { "src": "/api/disconnect-item",   "dest": "/api/disconnect_item.js" },
    { "src": "/api/delete-account",    "dest": "/api/delete_account.js" },
    { "src": "/api/migrate-plaid-item","dest": "/api/migrate_plaid_item.js" },
    { "src": "/api/transactions",      "dest": "/api/transactions.js" },
    { "src": "/api/transactions-enrich","dest": "/api/transactions_enrich.js" },
    { "src": "/api/liabilities",       "dest": "/api/liabilities.js" },
    { "src": "/api/balance",           "dest": "/api/balance.js" },
    { "src": "/api/analytics",         "dest": "/api/analytics.js" },
    { "src": "/api/copilot",           "dest": "/api/copilot.js" },
    { "src": "/api/email/(.*)",        "dest": "/api/email.js" }
  ],
  "crons": [
    {
      "path": "/api/email/scheduler",
      "schedule": "0 9 * * *"
    }
  ]
}
